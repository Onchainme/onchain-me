# Production env template for the frontend.
#
# NEXT_PUBLIC_* variables are inlined into the JS bundle at `next build` time.
# In docker-compose.prod.yml we pass this value as a build-arg to the frontend
# image; rebuild the image when the value changes.

NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Public origins for the two front-end domains. The marketing landing is served
# from the apex (NEXT_PUBLIC_LANDING_URL) and the app from a subdomain
# (NEXT_PUBLIC_APP_URL). Used to build cross-domain links (landing CTAs → app,
# app logo → landing). Leave unset to fall back to same-origin relative paths.
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_LANDING_URL=https://example.com
