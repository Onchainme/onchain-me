{
  "name": "onchain-me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mobile:build": "BUILD_TARGET=mobile dotenv -e .env.mobile -- next build",
    "mobile:sync": "npm run mobile:build && cap sync android",
    "mobile:open": "cap open android",
    "mobile:run": "npm run mobile:sync && cap run android",
    "mobile:apk": "npm run mobile:sync && cd android && ./gradlew assembleDebug && cd .. && echo 'APK: android/app/build/outputs/apk/debug/app-debug.apk'"
  },
  "dependencies": {
    "@olduvai-jp/pixi-animated-webp": "^1.0.4",
    "@phosphor-icons/react": "^2.1.10",
    "@pixi/react": "^8.0.5",
    "@solana/wallet-adapter-backpack": "^0.1.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "@capacitor/core": "^8.3.3",
    "bs58": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "pixi.js": "^8.18.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.3",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
