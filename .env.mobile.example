# Copy to .env.local (or pass inline) when running `npm run mobile:build`.
# These are baked into the static bundle at build time — change them and rebuild.

# Backend the Android WebView will hit. Must be a publicly reachable HTTPS URL
# in release builds. For emulator-only dev you can use http://10.0.2.2:3001
# (which points at the host machine's localhost from inside the emulator).
NEXT_PUBLIC_API_BASE_URL=http://10.0.2.2:3001

# Tells the app it is running inside Capacitor so the wallet-connect UI and
# wallet-gated nav items are stripped. Leave unset for normal web builds.
NEXT_PUBLIC_PLATFORM=mobile
